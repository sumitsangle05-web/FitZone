rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'sumitsangle05@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'trainerName', 'workoutType', 'dateTime', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.status in ['pending', 'confirmed', 'cancelled'] &&
             data.createdAt == request.time;
    }

    function isValidTrainer(data) {
      return data.keys().hasAll(['name', 'role', 'img', 'specialty', 'createdAt']) &&
             data.name is string &&
             data.createdAt == request.time;
    }

    // Collection Matches
    match /users/{userId} {
      allow get: if (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if (isOwner(userId) || isAdmin()) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
      );
    }

    match /bookings/{bookingId} {
      allow list: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow get: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && isValidBooking(incoming());
      allow update: if (isSignedIn() && existing().userId == request.auth.uid || isAdmin()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status in ['pending', 'confirmed', 'cancelled']
      );
    }

    match /userDiets/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create, update: if (isOwner(userId) || isAdmin()) && 
        incoming().keys().hasAll(['userId', 'goal', 'updatedAt']) &&
        (incoming().userId == request.auth.uid || isAdmin()) &&
        incoming().goal is string &&
        incoming().updatedAt == request.time;
    }

    match /userPrograms/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create, update: if (isOwner(userId) || isAdmin()) && 
        incoming().keys().hasAll(['userId', 'programId', 'enlistedAt']) &&
        (incoming().userId == request.auth.uid || isAdmin()) &&
        incoming().programId is string &&
        incoming().enlistedAt == request.time;
    }

    match /trainers/{trainerId} {
      allow read: if true;
      allow write: if isAdmin() && isValidTrainer(incoming());
    }

    match /orders/{orderId} {
      allow list: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow get: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && (
        incoming().keys().hasAll(['userId', 'userEmail', 'productName', 'price', 'status', 'createdAt']) &&
        incoming().userId == request.auth.uid &&
        incoming().status == 'pending' &&
        incoming().createdAt == request.time
      );
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status in ['pending', 'processing', 'completed']
      );
      allow delete: if isAdmin();
    }
  }
}
